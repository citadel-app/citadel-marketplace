{
  "name": "citadel-plugin-rss",
  "version": "1.0.0",
  "description": "Native RSS feed reading and aggregation for Citadel.",
  "author": "Citadel Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/citadel-app/citadel-plugin-rss"
  },
  "engines": {
    "citadel": ">=1.0.0"
  },
  "citadel": {
    "title": "RSS Reader",
    "icon": "assets/icon.png",
    "bundleUrl": "https://github.com/citadel-app/citadel-plugin-rss/releases/latest/download/citadel-plugin-rss.zip",
    "capabilities": [
      "getFeedItems",
      "saveFeedItems",
      "getFeedStatus",
      "updateFeedStatus"
    ],
    "permissions": [
      "fs.readFile",
      "fs.writeFile",
      "fs.exists",
      "fs.createDirectory",
      "app.updateSetting"
    ]
  }
}
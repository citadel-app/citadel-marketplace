{
  "name": "@citadel-app/pdf",
  "version": "1.2.1",
  "description": "PDF viewer with highlighting and TTS support for Citadel.",
  "author": "Citadel Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citadel-app/citadel-plugin-pdf.git"
  },
  "engines": {
    "citadel": ">=1.2.1"
  },
  "citadel": {
    "title": "PDF Viewer",
    "icon": "assets/icon.png",
    "authorUrl": "https://github.com/citadel-app",
    "verified": true,
    "bundleUrl": "https://github.com/citadel-app/citadel-plugin-pdf/releases/download/v1.2.1/citadel-plugin-pdf.zip",
    "permissions": [
      "@citadel-app/base:fs.readFile",
      "@citadel-app/base:fs.exists",
      "@citadel-app/base:fs.writeFile",
      "@citadel-app/base:fs.createDirectory"
    ],
    "capabilities": [
      "tts.start",
      "tts.stop",
      "tts.status",
      "models.check",
      "models.download"
    ],
    "sidecars": [
      {
        "id": "tts-sidecar",
        "type": "docker"
      }
    ]
  }
}
